      "parameters": {
        "promptType": "define",
        "text": "=Analyze this wellness check-in data and determine the wellness status:\n\nName: {{ $json[\"Name \"] }}\nMood (1-10): {{ $json.Mood }}\nSleep Hours: {{ $json[\"Sleep Hours\"] }}\nExercise: {{ $json.Exercise }}\nReflection: {{ $json[\"Reflection \"] }}\n\nBased on this data, classify the wellness status as one of:\n- \"Healthy\" if mood >= 7, sleep >= 7 hours, exercise is Yes\n- \"Needs Attention\" if mood 4-6, sleep 4-6 hours, or exercise is No\n- \"Critical\" if mood <= 3, sleep < 4 hours\n\nReturn ONLY the status word: Healthy, Needs Attention, or Critical",
        "options": {
          "systemMessage": "You are a wellness data analyzer. Your role is to evaluate wellness check-in data and classify the wellness status based on mood, sleep, and exercise metrics. Always respond with exactly one of these status words: Healthy, Needs Attention, or Critical."
        }
      },
